# Backend (Deno)
PORT=8787
# Mit docker-compose aus diesem Repo: Host-Port 5433 → Container 5432
# Postgres muss laufen. Chat (/api/chat) braucht zudem einen agent_configs-Eintrag
# (User-spezifisch oder Template-Zuweisung); sonst antwortet das Backend mit HTTP 500.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/cos_agent
# Test-DB für E2E (gleiches Schema, eigene Datenbank; wird per Init-Skript angelegt)
DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5433/cos_agent_test
# `deno test` im backend: ohne diese Variablen → 127.0.0.1:5433/cos_agent_test (wie docker-compose)

# Mindestens 32 Zeichen; fehlt oder zu kurz → Prozess startet nicht
SERVICE_TOKEN=change-me-to-at-least-32-characters-long!!

# JWT: Secret zum Verifizieren (HS256); in Produktion stark und rotierbar halten
JWT_SECRET=change-me-jwt-secret-min-32-chars!!

# CORS: kommagetrennte Origins, kein Wildcard (*). Muss exakt der Browser-Origin entsprechen
# (Schema + Host + Port). „localhost“ und „127.0.0.1“ sind unterschiedliche Origins.
# Vite-Port anpassen (z. B. 5174), wenn vite.config server.port geändert wurde.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Frontend (Vite): optional frontend/.env.local mit VITE_API_URL (siehe frontend/.env.example).
# Wenn unset, nutzt das UI http://localhost:8090 — muss zum Backend-PORT passen.

# Anthropic Messages API; Pflicht, mindestens 20 Zeichen
ANTHROPIC_API_KEY=sk-ant-api-key-min-20-chars

# AES-256-GCM für OAuth-/Notion-Tokens in der DB; 64 Hex-Zeichen — Pflicht sobald Verbindungen genutzt werden
# ENCRYPTION_KEY=

# Google OAuth: „Verbindungen“ im UI + Token-Refresh für Gmail-Tool (lazy bis Tool/Nutzung)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8090/api/auth/google/callback
# FRONTEND_URL=http://localhost:5174
# Optional Legacy (wird nur genutzt, wenn GOOGLE_* nicht gesetzt): GMAIL_CLIENT_ID / GMAIL_CLIENT_SECRET
